# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── Auth (RBAC) ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-secret
JWT_TTL_HOURS=8

# ── Required for embed.py --model openai and answer.py (OpenAI models) ────────
OPENAI_API_KEY=sk-...

# ── Required for contextualize.py --model gpt-5.4-mini (default) ─────────────
# Uses the same OPENAI_API_KEY above — no separate key needed

# ── Optional — Cohere reranker (retrieve.py --reranker cohere) ────────────────
COHERE_API_KEY=

# ── Optional — Voyage AI embeddings (voyage-finance-2) ───────────────────────
VOYAGE_API_KEY=

# ── ChromaDB (if not using Docker defaults) ───────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
